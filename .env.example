# ================================================================
# 네이버 카페 IT 교육 게시글 모니터 — 환경 변수 설정
# 이 파일을 복사하여 .env 파일을 만들고 값을 채워 주세요.
# cp .env.example .env
# ================================================================

# ── Naver 로그인 쿠키 ───────────────────────────────────────────
# 아래 방법으로 쿠키값을 확인할 수 있습니다:
#   1. Chrome 브라우저에서 https://cafe.naver.com 로그인
#   2. F12 → Application → Cookies → https://cafe.naver.com
#   3. NID_AUT, NID_SES 값을 복사
NAVER_NID_AUT=여기에_NID_AUT_값_입력
NAVER_NID_SES=여기에_NID_SES_값_입력

# ── GitHub 설정 ─────────────────────────────────────────────────
# GitHub Personal Access Token (repo 권한 필요)
# https://github.com/settings/tokens → Generate new token → repo 체크
GITHUB_TOKEN=여기에_GitHub_토큰_입력

# GitHub 사용자명 (레포지토리 소유자)
GITHUB_USERNAME=여기에_GitHub_사용자명_입력

# 수집된 게시글을 저장할 레포지토리 이름 (없으면 자동 생성)
GITHUB_REPO=naver-cafe-it-posts

# ── 폴링 주기 ────────────────────────────────────────────────────
# 게시판 스캔 주기 (분 단위, 기본값: 30)
POLL_INTERVAL_MINUTES=30
